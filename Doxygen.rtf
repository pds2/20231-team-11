644 {\cf20 // Calculate linear interpolation between two vectors}\par
645 RMAPI Vector3 Vector3Lerp(Vector3 v1, Vector3 v2, {\cf18 float} amount)\par
646 \{\par
647     Vector3 result = \{ 0 \};\par
648 \par
649     result.x = v1.x + amount*(v2.x - v1.x);\par
650     result.y = v1.y + amount*(v2.y - v1.y);\par
651     result.z = v1.z + amount*(v2.z - v1.z);\par
652 \par
653     {\cf19 return} result;\par
