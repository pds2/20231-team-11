581 {\cf20 // Orthonormalize provided vectors}\par
582 {\cf20 // Makes vectors normalized and orthogonal to each other}\par
583 {\cf20 // Gram-Schmidt function implementation}\par
584 RMAPI {\cf18 void} Vector3OrthoNormalize(Vector3 *v1, Vector3 *v2)\par
585 \{\par
586     {\cf18 float} length = 0.0f;\par
587     {\cf18 float} ilength = 0.0f;\par
588 \par
589     {\cf20 // Vector3Normalize(*v1);}\par
590     Vector3 v = *v1;\par
591     length = sqrtf(v.x*v.x + v.y*v.y + v.z*v.z);\par
592     {\cf19 if} (length == 0.0f) length = 1.0f;\par
593     ilength = 1.0f/length;\par
594     v1->x *= ilength;\par
595     v1->y *= ilength;\par
596     v1->z *= ilength;\par
597 \par
598     {\cf20 // Vector3CrossProduct(*v1, *v2)}\par
599     Vector3 vn1 = \{ v1->y*v2->z - v1->z*v2->y, v1->z*v2->x - v1->x*v2->z, v1->x*v2->y - v1->y*v2->x \};\par
600 \par
601     {\cf20 // Vector3Normalize(vn1);}\par
602     v = vn1;\par
603     length = sqrtf(v.x*v.x + v.y*v.y + v.z*v.z);\par
604     {\cf19 if} (length == 0.0f) length = 1.0f;\par
605     ilength = 1.0f/length;\par
606     vn1.x *= ilength;\par
607     vn1.y *= ilength;\par
608     vn1.z *= ilength;\par
609 \par
610     {\cf20 // Vector3CrossProduct(vn1, *v1)}\par
611     Vector3 vn2 = \{ vn1.y*v1->z - vn1.z*v1->y, vn1.z*v1->x - vn1.x*v1->z, vn1.x*v1->y - vn1.y*v1->x \};\par
612 \par
613     *v2 = vn2;\par
614 \}\par
