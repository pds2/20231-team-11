245 \par
246     {\cf19 return} result;\par
247 \}\par
248 \par
249 {\cf20 // Calculate vector length}\par
250 RMAPI {\cf18 float} Vector2Length(Vector2 v)\par
251 \{\par
252     {\cf18 float} result = sqrtf((v.x*v.x) + (v.y*v.y));\par
253 \par
254     {\cf19 return} result;\par
255 \}\par
256 \par
257 {\cf20 // Calculate vector square length}\par
258 RMAPI {\cf18 float} Vector2LengthSqr(Vector2 v)\par
259 \{\par
