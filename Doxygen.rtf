1060 {\cf20 // Create rotation matrix from axis and angle}\par
1061 {\cf20 // NOTE: Angle should be provided in radians}\par
1062 RMAPI Matrix MatrixRotate(Vector3 axis, {\cf18 float} angle)\par
1063 \{\par
1064     Matrix result = \{ 0 \};\par
1065 \par
1066     {\cf18 float} x = axis.x, y = axis.y, z = axis.z;\par
1067 \par
1068     {\cf18 float} lengthSquared = x*x + y*y + z*z;\par
1069 \par
1070     {\cf19 if} ((lengthSquared != 1.0f) && (lengthSquared != 0.0f))\par
1071     \{\par
1072         {\cf18 float} ilength = 1.0f/sqrtf(lengthSquared);\par
1073         x *= ilength;\par
1074         y *= ilength;\par
1075         z *= ilength;\par
1076     \}\par
1077 \par
1078     {\cf18 float} sinres = sinf(angle);\par
1079     {\cf18 float} cosres = cosf(angle);\par
1080     {\cf18 float} t = 1.0f - cosres;\par
1081 \par
1082     result.m0 = x*x*t + cosres;\par
1083     result.m1 = y*x*t + z*sinres;\par
1084     result.m2 = z*x*t - y*sinres;\par
1085     result.m3 = 0.0f;\par
1086 \par
1087     result.m4 = x*y*t - z*sinres;\par
1088     result.m5 = y*y*t + cosres;\par
1089     result.m6 = z*y*t + x*sinres;\par
1090     result.m7 = 0.0f;\par
1091 \par
1092     result.m8 = x*z*t + y*sinres;\par
1093     result.m9 = y*z*t - x*sinres;\par
1094     result.m10 = z*z*t + cosres;\par
1095     result.m11 = 0.0f;\par
1096 \par
1097     result.m12 = 0.0f;\par
1098     result.m13 = 0.0f;\par
1099     result.m14 = 0.0f;\par
1100     result.m15 = 1.0f;\par
1101 \par
1102     {\cf19 return} result;\par
1103 \}\par
