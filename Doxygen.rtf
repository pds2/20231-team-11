698 {\cf20 // Compute barycenter coordinates (u, v, w) for point p with respect to triangle (a, b, c)}\par
699 {\cf20 // NOTE: Assumes P is on the plane of the triangle}\par
700 RMAPI Vector3 Vector3Barycenter(Vector3 p, Vector3 a, Vector3 b, Vector3 c)\par
701 \{\par
702     Vector3 result = \{ 0 \};\par
703 \par
704     Vector3 v0 = \{ b.x - a.x, b.y - a.y, b.z - a.z \};   {\cf20 // Vector3Subtract(b, a)}\par
705     Vector3 v1 = \{ c.x - a.x, c.y - a.y, c.z - a.z \};   {\cf20 // Vector3Subtract(c, a)}\par
706     Vector3 v2 = \{ p.x - a.x, p.y - a.y, p.z - a.z \};   {\cf20 // Vector3Subtract(p, a)}\par
707     {\cf18 float} d00 = (v0.x*v0.x + v0.y*v0.y + v0.z*v0.z);    {\cf20 // Vector3DotProduct(v0, v0)}\par
708     {\cf18 float} d01 = (v0.x*v1.x + v0.y*v1.y + v0.z*v1.z);    {\cf20 // Vector3DotProduct(v0, v1)}\par
709     {\cf18 float} d11 = (v1.x*v1.x + v1.y*v1.y + v1.z*v1.z);    {\cf20 // Vector3DotProduct(v1, v1)}\par
710     {\cf18 float} d20 = (v2.x*v0.x + v2.y*v0.y + v2.z*v0.z);    {\cf20 // Vector3DotProduct(v2, v0)}\par
711     {\cf18 float} d21 = (v2.x*v1.x + v2.y*v1.y + v2.z*v1.z);    {\cf20 // Vector3DotProduct(v2, v1)}\par
712 \par
713     {\cf18 float} denom = d00*d11 - d01*d01;\par
714 \par
715     result.y = (d11*d20 - d01*d21)/denom;\par
716     result.z = (d00*d21 - d01*d20)/denom;\par
717     result.x = 1.0f - (result.z + result.y);\par
718 \par
719     {\cf19 return} result;\par
720 \}\par
721 \par
722 {\cf20 // Projects a Vector3 from screen space into object space}\par
723 {\cf20 // NOTE: We are avoiding calling other raymath functions despite available}\par
724 RMAPI Vector3 Vector3Unproject(Vector3 source, Matrix projection, Matrix view)\par
725 \{\par
726     Vector3 result = \{ 0 \};\par
727 \par
728     {\cf20 // Calculate unproject matrix (multiply view patrix by projection matrix) and invert it}\par
729     Matrix matViewProj = \{      {\cf20 // MatrixMultiply(view, projection);}\par
730         view.m0*projection.m0 + view.m1*projection.m4 + view.m2*projection.m8 + view.m3*projection.m12,\par
731         view.m0*projection.m1 + view.m1*projection.m5 + view.m2*projection.m9 + view.m3*projection.m13,\par
732         view.m0*projection.m2 + view.m1*projection.m6 + view.m2*projection.m10 + view.m3*projection.m14,\par
733         view.m0*projection.m3 + view.m1*projection.m7 + view.m2*projection.m11 + view.m3*projection.m15,\par
734         view.m4*projection.m0 + view.m5*projection.m4 + view.m6*projection.m8 + view.m7*projection.m12,\par
735         view.m4*projection.m1 + view.m5*projection.m5 + view.m6*projection.m9 + view.m7*projection.m13,\par
736         view.m4*projection.m2 + view.m5*projection.m6 + view.m6*projection.m10 + view.m7*projection.m14,\par
737         view.m4*projection.m3 + view.m5*projection.m7 + view.m6*projection.m11 + view.m7*projection.m15,\par
738         view.m8*projection.m0 + view.m9*projection.m4 + view.m10*projection.m8 + view.m11*projection.m12,\par
739         view.m8*projection.m1 + view.m9*projection.m5 + view.m10*projection.m9 + view.m11*projection.m13,\par
740         view.m8*projection.m2 + view.m9*projection.m6 + view.m10*projection.m10 + view.m11*projection.m14,\par
741         view.m8*projection.m3 + view.m9*projection.m7 + view.m10*projection.m11 + view.m11*projection.m15,\par
742         view.m12*projection.m0 + view.m13*projection.m4 + view.m14*projection.m8 + view.m15*projection.m12,\par
743         view.m12*projection.m1 + view.m13*projection.m5 + view.m14*projection.m9 + view.m15*projection.m13,\par
744         view.m12*projection.m2 + view.m13*projection.m6 + view.m14*projection.m10 + view.m15*projection.m14,\par
745         view.m12*projection.m3 + view.m13*projection.m7 + view.m14*projection.m11 + view.m15*projection.m15 \};\par
746 \par
747     {\cf20 // Calculate inverted matrix -> MatrixInvert(matViewProj);}\par
748     {\cf20 // Cache the matrix values (speed optimization)}\par
749     {\cf18 float} a00 = matViewProj.m0, a01 = matViewProj.m1, a02 = matViewProj.m2, a03 = matViewProj.m3;\par
750     {\cf18 float} a10 = matViewProj.m4, a11 = matViewProj.m5, a12 = matViewProj.m6, a13 = matViewProj.m7;\par
751     {\cf18 float} a20 = matViewProj.m8, a21 = matViewProj.m9, a22 = matViewProj.m10, a23 = matViewProj.m11;\par
752     {\cf18 float} a30 = matViewProj.m12, a31 = matViewProj.m13, a32 = matViewProj.m14, a33 = matViewProj.m15;\par
753 \par
754     {\cf18 float} b00 = a00*a11 - a01*a10;\par
755     {\cf18 float} b01 = a00*a12 - a02*a10;\par
756     {\cf18 float} b02 = a00*a13 - a03*a10;\par
757     {\cf18 float} b03 = a01*a12 - a02*a11;\par
758     {\cf18 float} b04 = a01*a13 - a03*a11;\par
759     {\cf18 float} b05 = a02*a13 - a03*a12;\par
760     {\cf18 float} b06 = a20*a31 - a21*a30;\par
761     {\cf18 float} b07 = a20*a32 - a22*a30;\par
762     {\cf18 float} b08 = a20*a33 - a23*a30;\par
763     {\cf18 float} b09 = a21*a32 - a22*a31;\par
764     {\cf18 float} b10 = a21*a33 - a23*a31;\par
765     {\cf18 float} b11 = a22*a33 - a23*a32;\par
766 \par
767     {\cf20 // Calculate the invert determinant (inlined to avoid double-caching)}\par
768     {\cf18 float} invDet = 1.0f/(b00*b11 - b01*b10 + b02*b09 + b03*b08 - b04*b07 + b05*b06);\par
769 \par
770     Matrix matViewProjInv = \{\par
771         (a11*b11 - a12*b10 + a13*b09)*invDet,\par
772         (-a01*b11 + a02*b10 - a03*b09)*invDet,\par
773         (a31*b05 - a32*b04 + a33*b03)*invDet,\par
774         (-a21*b05 + a22*b04 - a23*b03)*invDet,\par
775         (-a10*b11 + a12*b08 - a13*b07)*invDet,\par
776         (a00*b11 - a02*b08 + a03*b07)*invDet,\par
777         (-a30*b05 + a32*b02 - a33*b01)*invDet,\par
778         (a20*b05 - a22*b02 + a23*b01)*invDet,\par
779         (a10*b10 - a11*b08 + a13*b06)*invDet,\par
780         (-a00*b10 + a01*b08 - a03*b06)*invDet,\par
781         (a30*b04 - a31*b02 + a33*b00)*invDet,\par
782         (-a20*b04 + a21*b02 - a23*b00)*invDet,\par
783         (-a10*b09 + a11*b07 - a12*b06)*invDet,\par
784         (a00*b09 - a01*b07 + a02*b06)*invDet,\par
785         (-a30*b03 + a31*b01 - a32*b00)*invDet,\par
786         (a20*b03 - a21*b01 + a22*b00)*invDet \};\par
787 \par
788     {\cf20 // Create quaternion from source point}\par
789     Quaternion quat = \{ source.x, source.y, source.z, 1.0f \};\par
790 \par
791     {\cf20 // Multiply quat point by unproject matrix}\par
792     Quaternion qtransformed = \{     {\cf20 // QuaternionTransform(quat, matViewProjInv)}\par
793         matViewProjInv.m0*quat.x + matViewProjInv.m4*quat.y + matViewProjInv.m8*quat.z + matViewProjInv.m12*quat.w,\par
794         matViewProjInv.m1*quat.x + matViewProjInv.m5*quat.y + matViewProjInv.m9*quat.z + matViewProjInv.m13*quat.w,\par
795         matViewProjInv.m2*quat.x + matViewProjInv.m6*quat.y + matViewProjInv.m10*quat.z + matViewProjInv.m14*quat.w,\par
796         matViewProjInv.m3*quat.x + matViewProjInv.m7*quat.y + matViewProjInv.m11*quat.z + matViewProjInv.m15*quat.w \};\par
797 \par
798     {\cf20 // Normalized world points in vectors}\par
799     result.x = qtransformed.x/qtransformed.w;\par
800     result.y = qtransformed.y/qtransformed.w;\par
801     result.z = qtransformed.z/qtransformed.w;\par
802 \par
803     {\cf19 return} result;\par
804 \}\par
