616 {\cf20 // Transforms a Vector3 by a given Matrix}\par
617 RMAPI Vector3 Vector3Transform(Vector3 v, Matrix mat)\par
618 \{\par
619     Vector3 result = \{ 0 \};\par
620 \par
621     {\cf18 float} x = v.x;\par
622     {\cf18 float} y = v.y;\par
623     {\cf18 float} z = v.z;\par
624 \par
625     result.x = mat.m0*x + mat.m4*y + mat.m8*z + mat.m12;\par
626     result.y = mat.m1*x + mat.m5*y + mat.m9*z + mat.m13;\par
627     result.z = mat.m2*x + mat.m6*y + mat.m10*z + mat.m14;\par
628 \par
629     {\cf19 return} result;\par
630 \}\par
