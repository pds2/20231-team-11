656 {\cf20 // Calculate reflected vector to normal}\par
657 RMAPI Vector3 Vector3Reflect(Vector3 v, Vector3 normal)\par
658 \{\par
659     Vector3 result = \{ 0 \};\par
660 \par
661     {\cf20 // I is the original vector}\par
662     {\cf20 // N is the normal of the incident plane}\par
663     {\cf20 // R = I - (2*N*(DotProduct[I, N]))}\par
664 \par
665     {\cf18 float} dotProduct = (v.x*normal.x + v.y*normal.y + v.z*normal.z);\par
666 \par
667     result.x = v.x - (2.0f*normal.x)*dotProduct;\par
668     result.y = v.y - (2.0f*normal.y)*dotProduct;\par
669     result.z = v.z - (2.0f*normal.z)*dotProduct;\par
670 \par
671     {\cf19 return} result;\par
672 \}\par
