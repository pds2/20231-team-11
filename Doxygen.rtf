1521     result.y = qay*mul + qaw*mul + qaz*mul - qax*mul;\par
1522     result.z = qaz*mul + qaw*mul + qax*mul - qay*mul;\par
1523     result.w = qaw*mul - qax*mul - qay*mul - qaz*mul;\par
1524 \par
1525     {\cf19 return} result;\par
1526 \}\par
