1820 \par
1821     {\cf20 // Roll (x-axis rotation)}\par
1822     {\cf18 float} x0 = 2.0f*(q.w*q.x + q.y*q.z);\par
1823     {\cf18 float} x1 = 1.0f - 2.0f*(q.x*q.x + q.y*q.y);\par
