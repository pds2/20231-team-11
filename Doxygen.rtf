{\b 
{\b RMAPI} {\b Vector3} Vector3Perpendicular ({\b Vector3}  {\i v})}}
\par
{\bkmkstart AAAAAAACHY}
{\bkmkend AAAAAAACHY}
{
\pard\plain \s61\li360\sa60\sb30\qj\widctlpar\qj\adjustright \fs20\cgrid 
{
\pard\plain \s41\li360\widctlpar\adjustright \shading1000\cbpat8 \f2\fs16\cgrid 470 \{\par
471     Vector3 result = \{ 0 \};\par
472 \par
473     {\cf18 float} min = (float) fabs(v.x);\par
474     Vector3 cardinalAxis = \{1.0f, 0.0f, 0.0f\};\par
475 \par
476     {\cf19 if} (fabs(v.y) < min)\par
477     \{\par
478         min = (float) fabs(v.y);\par
479         Vector3 tmp = \{0.0f, 1.0f, 0.0f\};\par
480         cardinalAxis = tmp;\par
481     \}\par
482 \par
483     {\cf19 if} (fabs(v.z) < min)\par
484     \{\par
485         Vector3 tmp = \{0.0f, 0.0f, 1.0f\};\par
486         cardinalAxis = tmp;\par
487     \}\par
488 \par
489     {\cf20 // Cross product between vectors}\par
490     result.x = v.y*cardinalAxis.z - v.z*cardinalAxis.y;\par
491     result.y = v.z*cardinalAxis.x - v.x*cardinalAxis.z;\par
492     result.z = v.x*cardinalAxis.y - v.y*cardinalAxis.x;\par
493 \par
494     {\cf19 return} result;\par
495 \}\par
}
}
{\xe \v Vector3Reflect\:raymath.h}
