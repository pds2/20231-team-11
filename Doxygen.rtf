566 RMAPI Vector3 Vector3Normalize(Vector3 v)\par
567 \{\par
568     Vector3 result = v;\par
569 \par
570     {\cf18 float} length = sqrtf(v.x*v.x + v.y*v.y + v.z*v.z);\par
571     {\cf19 if} (length == 0.0f) length = 1.0f;\par
572     {\cf18 float} ilength = 1.0f/length;\par
573 \par
574     result.x *= ilength;\par
575     result.y *= ilength;\par
576     result.z *= ilength;\par
577 \par
578     {\cf19 return} result;\par
579 \}\par
