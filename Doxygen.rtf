822 {\cf20 // Compute matrix determinant}\par
823 RMAPI {\cf18 float} MatrixDeterminant(Matrix mat)\par
824 \{\par
825     {\cf18 float} result = 0.0f;\par
826 \par
827     {\cf20 // Cache the matrix values (speed optimization)}\par
828     {\cf18 float} a00 = mat.m0, a01 = mat.m1, a02 = mat.m2, a03 = mat.m3;\par
829     {\cf18 float} a10 = mat.m4, a11 = mat.m5, a12 = mat.m6, a13 = mat.m7;\par
830     {\cf18 float} a20 = mat.m8, a21 = mat.m9, a22 = mat.m10, a23 = mat.m11;\par
831     {\cf18 float} a30 = mat.m12, a31 = mat.m13, a32 = mat.m14, a33 = mat.m15;\par
832 \par
833     result = a30*a21*a12*a03 - a20*a31*a12*a03 - a30*a11*a22*a03 + a10*a31*a22*a03 +\par
834              a20*a11*a32*a03 - a10*a21*a32*a03 - a30*a21*a02*a13 + a20*a31*a02*a13 +\par
835              a30*a01*a22*a13 - a00*a31*a22*a13 - a20*a01*a32*a13 + a00*a21*a32*a13 +\par
836              a30*a11*a02*a23 - a10*a31*a02*a23 - a30*a01*a12*a23 + a00*a31*a12*a23 +\par
837              a10*a01*a32*a23 - a00*a11*a32*a23 - a20*a11*a02*a33 + a10*a21*a02*a33 +\par
838              a20*a01*a12*a33 - a00*a21*a12*a33 - a10*a01*a22*a33 + a00*a11*a22*a33;\par
839 \par
840     {\cf19 return} result;\par
841 \}\par
