295 \par
296     {\cf19 return} result;\par
297 \}\par
298 \par
299 {\cf20 // Multiply vector by vector}\par
300 RMAPI Vector2 Vector2Multiply(Vector2 v1, Vector2 v2)\par
301 \{\par
302     Vector2 result = \{ v1.x*v2.x, v1.y*v2.y \};\par
303 \par
304     {\cf19 return} result;\par
305 \}\par
306 \par
307 {\cf20 // Negate vector}\par
308 RMAPI Vector2 Vector2Negate(Vector2 v)\par
309 \{\par
310     Vector2 result = \{ -v.x, -v.y \};\par
311 \par
312     {\cf19 return} result;\par
313 \}\par
314 \par
315 {\cf20 // Divide vector by vector}\par
316 RMAPI Vector2 Vector2Divide(Vector2 v1, Vector2 v2)\par
317 \{\par
318     Vector2 result = \{ v1.x/v2.x, v1.y/v2.y \};\par
319 \par
320     {\cf19 return} result;\par
321 \}\par
322 \par
323 {\cf20 // Normalize provided vector}\par
324 RMAPI Vector2 Vector2Normalize(Vector2 v)\par
325 \{\par
326     Vector2 result = \{ 0 \};\par
327     {\cf18 float} length = sqrtf((v.x*v.x) + (v.y*v.y));\par
328 \par
329     {\cf19 if} (length > 0)\par
330     \{\par
331         result.x = v.x*1.0f/length;\par
332         result.y = v.y*1.0f/length;\par
333     \}\par
334 \par
335     {\cf19 return} result;\par
336 \}\par
337 \par
338 {\cf20 // Calculate linear interpolation between two vectors}\par
339 RMAPI Vector2 Vector2Lerp(Vector2 v1, Vector2 v2, {\cf18 float} amount)\par
340 \{\par
341     Vector2 result = \{ 0 \};\par
342 \par
343     result.x = v1.x + amount*(v2.x - v1.x);\par
344     result.y = v1.y + amount*(v2.y - v1.y);\par
345 \par
346     {\cf19 return} result;\par
347 \}\par
348 \par
349 {\cf20 // Calculate reflected vector to normal}\par
350 RMAPI Vector2 Vector2Reflect(Vector2 v, Vector2 normal)\par
351 \{\par
352     Vector2 result = \{ 0 \};\par
353 \par
354     {\cf18 float} dotProduct = (v.x*normal.x + v.y*normal.y); {\cf20 // Dot product}\par
355 \par
356     result.x = v.x - (2.0f*normal.x)*dotProduct;\par
357     result.y = v.y - (2.0f*normal.y)*dotProduct;\par
358 \par
359     {\cf19 return} result;\par
360 \}\par
361 \par
362 {\cf20 // Rotate vector by angle}\par
363 RMAPI Vector2 Vector2Rotate(Vector2 v, {\cf18 float} angle)\par
364 \{\par
365     Vector2 result = \{ 0 \};\par
366 \par
367     result.x = v.x*cosf(angle) - v.y*sinf(angle);\par
368     result.y = v.x*sinf(angle) + v.y*cosf(angle);\par
369 \par
370     {\cf19 return} result;\par
371 \}\par
372 \par
373 {\cf20 // Move Vector towards target}\par
374 RMAPI Vector2 Vector2MoveTowards(Vector2 v, Vector2 target, {\cf18 float} maxDistance)\par
375 \{\par
376     Vector2 result = \{ 0 \};\par
377 \par
378     {\cf18 float} dx = target.x - v.x;\par
379     {\cf18 float} dy = target.y - v.y;\par
380     {\cf18 float} value = (dx*dx) + (dy*dy);\par
381 \par
382     {\cf19 if} ((value == 0) || ((maxDistance >= 0) && (value <= maxDistance*maxDistance))) {\cf19 return} target;\par
383 \par
384     {\cf18 float} dist = sqrtf(value);\par
385 \par
386     result.x = v.x + dx/dist*maxDistance;\par
387     result.y = v.y + dy/dist*maxDistance;\par
388 \par
389     {\cf19 return} result;\par
390 \}\par
