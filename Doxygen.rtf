261 \par
262     {\cf19 return} result;\par
263 \}\par
264 \par
265 {\cf20 // Calculate two vectors dot product}\par
266 RMAPI {\cf18 float} Vector2DotProduct(Vector2 v1, Vector2 v2)\par
267 \{\par
268     {\cf18 float} result = (v1.x*v2.x + v1.y*v2.y);\par
269 \par
270     {\cf19 return} result;\par
271 \}\par
272 \par
273 {\cf20 // Calculate distance between two vectors}\par
274 RMAPI {\cf18 float} Vector2Distance(Vector2 v1, Vector2 v2)\par
275 \{\par
276     {\cf18 float} result = sqrtf((v1.x - v2.x)*(v1.x - v2.x) + (v1.y - v2.y)*(v1.y - v2.y));\par
277 \par
278     {\cf19 return} result;\par
279 \}\par
280 \par
281 {\cf20 // Calculate angle from two vectors in X-axis}\par
282 RMAPI {\cf18 float} Vector2Angle(Vector2 v1, Vector2 v2)\par
283 \{\par
284     {\cf18 float} result = atan2f(v2.y - v1.y, v2.x - v1.x)*(180.0f/PI);\par
285 \par
286     {\cf19 if} (result < 0) result += 360.0f;\par
287 \par
288     {\cf19 return} result;\par
289 \}\par
