1280     {\cf18 double} left = -right;\par
1281 \par
1282     {\cf20 // MatrixFrustum(-right, right, -top, top, near, far);}\par
1283     {\cf18 float} rl = (float)(right - left);\par
1284     {\cf18 float} tb = (float)(top - bottom);\par
1285     {\cf18 float} fn = (float)(far - near);\par
1286 \par
1287     result.m0 = ((float)near*2.0f)/rl;\par
1288     result.m5 = ((float)near*2.0f)/tb;\par
1289     result.m8 = ((float)right + ({\cf18 float})left)/rl;\par
1290     result.m9 = ((float)top + ({\cf18 float})bottom)/tb;\par
1291     result.m10 = -((float)far + ({\cf18 float})near)/fn;\par
1292     result.m11 = -1.0f;\par
1293     result.m14 = -((float)far*({\cf18 float})near*2.0f)/fn;\par
1294 \par
1295     {\cf19 return} result;\par
1296 \}\par
