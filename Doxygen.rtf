1325 \}\par
1326 \par
1327 {\cf20 // Get camera look-at matrix (view matrix)}\par
1328 RMAPI Matrix MatrixLookAt(Vector3 eye, Vector3 target, Vector3 up)\par
1329 \{\par
1330     Matrix result = \{ 0 \};\par
1331 \par
1332     {\cf18 float} length = 0.0f;\par
1333     {\cf18 float} ilength = 0.0f;\par
1334 \par
1335     {\cf20 // Vector3Subtract(eye, target)}\par
1336     Vector3 vz = \{ eye.x - target.x, eye.y - target.y, eye.z - target.z \};\par
1337 \par
1338     {\cf20 // Vector3Normalize(vz)}\par
1339     Vector3 v = vz;\par
1340     length = sqrtf(v.x*v.x + v.y*v.y + v.z*v.z);\par
1341     {\cf19 if} (length == 0.0f) length = 1.0f;\par
1342     ilength = 1.0f/length;\par
1343     vz.x *= ilength;\par
1344     vz.y *= ilength;\par
1345     vz.z *= ilength;\par
1346 \par
1347     {\cf20 // Vector3CrossProduct(up, vz)}\par
1348     Vector3 vx = \{ up.y*vz.z - up.z*vz.y, up.z*vz.x - up.x*vz.z, up.x*vz.y - up.y*vz.x \};\par
1349 \par
1350     {\cf20 // Vector3Normalize(x)}\par
1351     v = vx;\par
1352     length = sqrtf(v.x*v.x + v.y*v.y + v.z*v.z);\par
1353     {\cf19 if} (length == 0.0f) length = 1.0f;\par
1354     ilength = 1.0f/length;\par
1355     vx.x *= ilength;\par
1356     vx.y *= ilength;\par
1357     vx.z *= ilength;\par
1358 \par
1359     {\cf20 // Vector3CrossProduct(vz, vx)}\par
1360     Vector3 vy = \{ vz.y*vx.z - vz.z*vx.y, vz.z*vx.x - vz.x*vx.z, vz.x*vx.y - vz.y*vx.x \};\par
1361 \par
1362     result.m0 = vx.x;\par
1363     result.m1 = vy.x;\par
1364     result.m2 = vz.x;\par
1365     result.m3 = 0.0f;\par
1366     result.m4 = vx.y;\par
1367     result.m5 = vy.y;\par
1368     result.m6 = vz.y;\par
1369     result.m7 = 0.0f;\par
1370     result.m8 = vx.z;\par
1371     result.m9 = vy.z;\par
1372     result.m10 = vz.z;\par
1373     result.m11 = 0.0f;\par
1374     result.m12 = -(vx.x*eye.x + vx.y*eye.y + vx.z*eye.z);   {\cf20 // Vector3DotProduct(vx, eye)}\par
1375     result.m13 = -(vy.x*eye.x + vy.y*eye.y + vy.z*eye.z);   {\cf20 // Vector3DotProduct(vy, eye)}\par
1376     result.m14 = -(vz.x*eye.x + vz.y*eye.y + vz.z*eye.z);   {\cf20 // Vector3DotProduct(vz, eye)}\par
1377     result.m15 = 1.0f;\par
1378 \par
1379     {\cf19 return} result;\par
1380 \}\par
1381 \par
1382 {\cf20 // Get float array of matrix data}\par
1383 RMAPI float16 MatrixToFloatV(Matrix mat)\par
1384 \{\par
1385     float16 result = \{ 0 \};\par
1386 \par
1387     result.v[0] = mat.m0;\par
