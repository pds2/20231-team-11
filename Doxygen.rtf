526     {\cf18 float} dx = v2.x - v1.x;\par
527     {\cf18 float} dy = v2.y - v1.y;\par
528     {\cf18 float} dz = v2.z - v1.z;\par
529     result = sqrtf(dx*dx + dy*dy + dz*dz);\par
530 \par
531     {\cf19 return} result;\par
532 \}\par
533 \par
534 {\cf20 // Calculate angle between two vectors in XY and XZ}\par
535 RMAPI Vector2 Vector3Angle(Vector3 v1, Vector3 v2)\par
536 \{\par
537     Vector2 result = \{ 0 \};\par
538 \par
539     {\cf18 float} dx = v2.x - v1.x;\par
540     {\cf18 float} dy = v2.y - v1.y;\par
541     {\cf18 float} dz = v2.z - v1.z;\par
542 \par
543     result.x = atan2f(dx, dz);                      {\cf20 // Angle in XZ}\par
544     result.y = atan2f(dy, sqrtf(dx*dx + dz*dz));    {\cf20 // Angle in XY}\par
545 \par
546     {\cf19 return} result;\par
547 \}\par
