1497 {\cf20 // Calculate two quaternion multiplication}\par
1498 RMAPI Quaternion QuaternionMultiply(Quaternion q1, Quaternion q2)\par
1499 \{\par
1500     Quaternion result = \{ 0 \};\par
1501 \par
1502     {\cf18 float} qax = q1.x, qay = q1.y, qaz = q1.z, qaw = q1.w;\par
1503     {\cf18 float} qbx = q2.x, qby = q2.y, qbz = q2.z, qbw = q2.w;\par
1504 \par
1505     result.x = qax*qbw + qaw*qbx + qay*qbz - qaz*qby;\par
1506     result.y = qay*qbw + qaw*qby + qaz*qbx - qax*qbz;\par
1507     result.z = qaz*qbw + qaw*qbz + qax*qby - qay*qbx;\par
1508     result.w = qaw*qbw - qax*qbx - qay*qby - qaz*qbz;\par
1509 \par
1510     {\cf19 return} result;\par
1511 \}\par
