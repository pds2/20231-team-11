1830     result.y = asinf(y0);\par
1831 \par
1832     {\cf20 // Yaw (z-axis rotation)}\par
1833     {\cf18 float} z0 = 2.0f*(q.w*q.z + q.x*q.y);\par
1834     {\cf18 float} z1 = 1.0f - 2.0f*(q.y*q.y + q.z*q.z);\par
