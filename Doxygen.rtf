201 {\cf20 // Vector with components value 0.0f}\par
202 RMAPI Vector2 Vector2Zero({\cf18 void})\par
203 \{\par
204     Vector2 result = \{ 0.0f, 0.0f \};\par
205 \par
206     {\cf19 return} result;\par
207 \}\par
208 \par
209 {\cf20 // Vector with components value 1.0f}\par
