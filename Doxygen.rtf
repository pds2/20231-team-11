632 {\cf20 // Transform a vector by quaternion rotation}\par
633 RMAPI Vector3 Vector3RotateByQuaternion(Vector3 v, Quaternion q)\par
634 \{\par
635     Vector3 result = \{ 0 \};\par
636 \par
637     result.x = v.x*(q.x*q.x + q.w*q.w - q.y*q.y - q.z*q.z) + v.y*(2*q.x*q.y - 2*q.w*q.z) + v.z*(2*q.x*q.z + 2*q.w*q.y);\par
638     result.y = v.x*(2*q.w*q.z + 2*q.x*q.y) + v.y*(q.w*q.w - q.x*q.x + q.y*q.y - q.z*q.z) + v.z*(-2*q.w*q.x + 2*q.y*q.z);\par
639     result.z = v.x*(-2*q.w*q.y + 2*q.x*q.z) + v.y*(2*q.w*q.x + 2*q.y*q.z)+ v.z*(q.w*q.w - q.x*q.x - q.y*q.y + q.z*q.z);\par
640 \par
641     {\cf19 return} result;\par
642 \}\par
