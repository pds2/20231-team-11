251         DrawText({\cf22 "Start"}, SCREEN_WIDTH / 2 - MeasureText({\cf22 "Start"}, 20) / 2, 200, 20, selected_option == 0 ? RED : WHITE);\par
252         DrawText({\cf22 "Exit"}, SCREEN_WIDTH / 2 - MeasureText({\cf22 "Exit"}, 20) / 2, 250, 20, selected_option == 1 ? RED : WHITE);\par
253 \par
