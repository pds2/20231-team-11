1317     result.m10 = -2.0f/fn;\par
1318     result.m11 = 0.0f;\par
1319     result.m12 = -((float)left + ({\cf18 float})right)/rl;\par
1320     result.m13 = -((float)top + ({\cf18 float})bottom)/tb;\par
1321     result.m14 = -((float)far + ({\cf18 float})near)/fn;\par
