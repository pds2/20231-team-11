162 \par
163 {\cf20 // Clamp float value}\par
164 RMAPI {\cf18 float} Clamp({\cf18 float} value, {\cf18 float} min, {\cf18 float} max)\par
165 \{\par
166     {\cf18 float} result = (value < min)? min : value;\par
167 \par
168     {\cf19 if} (result > max) result = max;\par
169 \par
170     {\cf19 return} result;\par
171 \}\par
172 \par
173 {\cf20 // Calculate linear interpolation between two floats}\par
174 RMAPI {\cf18 float} Lerp({\cf18 float} start, {\cf18 float} end, {\cf18 float} amount)\par
175 \{\par
176     {\cf18 float} result = start + amount*(end - start);\par
177 \par
178     {\cf19 return} result;\par
179 \}\par
180 \par
181 {\cf20 // Normalize input value within input range}\par
182 RMAPI {\cf18 float} Normalize({\cf18 float} value, {\cf18 float} start, {\cf18 float} end)\par
183 \{\par
184     {\cf18 float} result = (value - start)/(end - start);\par
185 \par
186     {\cf19 return} result;\par
187 \}\par
188 \par
189 {\cf20 // Remap input value within input range to output range}\par
190 RMAPI {\cf18 float} Remap({\cf18 float} value, {\cf18 float} inputStart, {\cf18 float} inputEnd, {\cf18 float} outputStart, {\cf18 float} outputEnd)\par
191 \{\par
192     {\cf18 float} result =(value - inputStart)/(inputEnd - inputStart)*(outputEnd - outputStart) + outputStart;\par
193 \par
194     {\cf19 return} result;\par
195 \}\par
