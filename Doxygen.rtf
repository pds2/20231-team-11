876 {\cf20 // Invert provided matrix}\par
877 RMAPI Matrix MatrixInvert(Matrix mat)\par
878 \{\par
879     Matrix result = \{ 0 \};\par
880 \par
881     {\cf20 // Cache the matrix values (speed optimization)}\par
882     {\cf18 float} a00 = mat.m0, a01 = mat.m1, a02 = mat.m2, a03 = mat.m3;\par
883     {\cf18 float} a10 = mat.m4, a11 = mat.m5, a12 = mat.m6, a13 = mat.m7;\par
884     {\cf18 float} a20 = mat.m8, a21 = mat.m9, a22 = mat.m10, a23 = mat.m11;\par
885     {\cf18 float} a30 = mat.m12, a31 = mat.m13, a32 = mat.m14, a33 = mat.m15;\par
886 \par
887     {\cf18 float} b00 = a00*a11 - a01*a10;\par
888     {\cf18 float} b01 = a00*a12 - a02*a10;\par
889     {\cf18 float} b02 = a00*a13 - a03*a10;\par
890     {\cf18 float} b03 = a01*a12 - a02*a11;\par
891     {\cf18 float} b04 = a01*a13 - a03*a11;\par
892     {\cf18 float} b05 = a02*a13 - a03*a12;\par
893     {\cf18 float} b06 = a20*a31 - a21*a30;\par
894     {\cf18 float} b07 = a20*a32 - a22*a30;\par
895     {\cf18 float} b08 = a20*a33 - a23*a30;\par
896     {\cf18 float} b09 = a21*a32 - a22*a31;\par
897     {\cf18 float} b10 = a21*a33 - a23*a31;\par
898     {\cf18 float} b11 = a22*a33 - a23*a32;\par
899 \par
900     {\cf20 // Calculate the invert determinant (inlined to avoid double-caching)}\par
901     {\cf18 float} invDet = 1.0f/(b00*b11 - b01*b10 + b02*b09 + b03*b08 - b04*b07 + b05*b06);\par
902 \par
903     result.m0 = (a11*b11 - a12*b10 + a13*b09)*invDet;\par
904     result.m1 = (-a01*b11 + a02*b10 - a03*b09)*invDet;\par
905     result.m2 = (a31*b05 - a32*b04 + a33*b03)*invDet;\par
906     result.m3 = (-a21*b05 + a22*b04 - a23*b03)*invDet;\par
907     result.m4 = (-a10*b11 + a12*b08 - a13*b07)*invDet;\par
908     result.m5 = (a00*b11 - a02*b08 + a03*b07)*invDet;\par
909     result.m6 = (-a30*b05 + a32*b02 - a33*b01)*invDet;\par
910     result.m7 = (a20*b05 - a22*b02 + a23*b01)*invDet;\par
911     result.m8 = (a10*b10 - a11*b08 + a13*b06)*invDet;\par
912     result.m9 = (-a00*b10 + a01*b08 - a03*b06)*invDet;\par
913     result.m10 = (a30*b04 - a31*b02 + a33*b00)*invDet;\par
914     result.m11 = (-a20*b04 + a21*b02 - a23*b00)*invDet;\par
915     result.m12 = (-a10*b09 + a11*b07 - a12*b06)*invDet;\par
916     result.m13 = (a00*b09 - a01*b07 + a02*b06)*invDet;\par
917     result.m14 = (-a30*b03 + a31*b01 - a32*b00)*invDet;\par
918     result.m15 = (a20*b03 - a21*b01 + a22*b00)*invDet;\par
919 \par
920     {\cf19 return} result;\par
921 \}\par
922 \par
923 {\cf20 // Normalize provided matrix}\par
924 RMAPI Matrix MatrixNormalize(Matrix mat)\par
925 \{\par
926     Matrix result = \{ 0 \};\par
927 \par
928     {\cf20 // Cache the matrix values (speed optimization)}\par
929     {\cf18 float} a00 = mat.m0, a01 = mat.m1, a02 = mat.m2, a03 = mat.m3;\par
930     {\cf18 float} a10 = mat.m4, a11 = mat.m5, a12 = mat.m6, a13 = mat.m7;\par
931     {\cf18 float} a20 = mat.m8, a21 = mat.m9, a22 = mat.m10, a23 = mat.m11;\par
932     {\cf18 float} a30 = mat.m12, a31 = mat.m13, a32 = mat.m14, a33 = mat.m15;\par
933 \par
934     {\cf20 // MatrixDeterminant(mat)}\par
935     {\cf18 float} det = a30*a21*a12*a03 - a20*a31*a12*a03 - a30*a11*a22*a03 + a10*a31*a22*a03 +\par
936                 a20*a11*a32*a03 - a10*a21*a32*a03 - a30*a21*a02*a13 + a20*a31*a02*a13 +\par
937                 a30*a01*a22*a13 - a00*a31*a22*a13 - a20*a01*a32*a13 + a00*a21*a32*a13 +\par
938                 a30*a11*a02*a23 - a10*a31*a02*a23 - a30*a01*a12*a23 + a00*a31*a12*a23 +\par
939                 a10*a01*a32*a23 - a00*a11*a32*a23 - a20*a11*a02*a33 + a10*a21*a02*a33 +\par
940                 a20*a01*a12*a33 - a00*a21*a12*a33 - a10*a01*a22*a33 + a00*a11*a22*a33;\par
941 \par
942     result.m0 = mat.m0/det;\par
943     result.m1 = mat.m1/det;\par
944     result.m2 = mat.m2/det;\par
945     result.m3 = mat.m3/det;\par
946     result.m4 = mat.m4/det;\par
947     result.m5 = mat.m5/det;\par
948     result.m6 = mat.m6/det;\par
