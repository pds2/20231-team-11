1239 {\cf20 // Get perspective projection matrix}\par
1240 RMAPI Matrix MatrixFrustum({\cf18 double} left, {\cf18 double} right, {\cf18 double} bottom, {\cf18 double} top, {\cf18 double} near, {\cf18 double} far)\par
1241 \{\par
1242     Matrix result = \{ 0 \};\par
1243 \par
1244     {\cf18 float} rl = (float)(right - left);\par
1245     {\cf18 float} tb = (float)(top - bottom);\par
1246     {\cf18 float} fn = (float)(far - near);\par
1247 \par
1248     result.m0 = ((float)near*2.0f)/rl;\par
1249     result.m1 = 0.0f;\par
1250     result.m2 = 0.0f;\par
1251     result.m3 = 0.0f;\par
1252 \par
1253     result.m4 = 0.0f;\par
1254     result.m5 = ((float)near*2.0f)/tb;\par
1255     result.m6 = 0.0f;\par
1256     result.m7 = 0.0f;\par
1257 \par
1258     result.m8 = ((float)right + ({\cf18 float})left)/rl;\par
1259     result.m9 = ((float)top + ({\cf18 float})bottom)/tb;\par
1260     result.m10 = -((float)far + ({\cf18 float})near)/fn;\par
1261     result.m11 = -1.0f;\par
1262 \par
1263     result.m12 = 0.0f;\par
1264     result.m13 = 0.0f;\par
1265     result.m14 = -((float)far*({\cf18 float})near*2.0f)/fn;\par
1266     result.m15 = 0.0f;\par
1267 \par
1268     {\cf19 return} result;\par
1269 \}\par
1270 \par
1271 {\cf20 // Get perspective projection matrix}\par
1272 {\cf20 // NOTE: Angle should be provided in radians}\par
1273 RMAPI Matrix MatrixPerspective({\cf18 double} fovy, {\cf18 double} aspect, {\cf18 double} near, {\cf18 double} far)\par
1274 \{\par
