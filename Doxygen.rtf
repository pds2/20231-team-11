{\xe \v QuaternionSlerp\:raymath.h}
{\xe \v raymath.h\:QuaternionSlerp}
\pard\plain \s4\sb240\sa60\keepn\widctlpar\adjustright \b\f1\fs20\cgrid {
{\b 
{\b RMAPI} {\b Quaternion} QuaternionSlerp ({\b Quaternion}  {\i q1}, {\b Quaternion}  {\i q2}, float  {\i amount})}}
\par
{\bkmkstart AAAAAAACGE}
{\bkmkend AAAAAAACGE}
{
\pard\plain \s61\li360\sa60\sb30\qj\widctlpar\qj\adjustright \fs20\cgrid 
{
\pard\plain \s41\li360\widctlpar\adjustright \shading1000\cbpat8 \f2\fs16\cgrid 1576 \{\par
1577     Quaternion result = \{ 0 \};\par
1578 \par
1579     {\cf18 float} cosHalfTheta = q1.x*q2.x + q1.y*q2.y + q1.z*q2.z + q1.w*q2.w;\par
1580 \par
1581     {\cf19 if} (cosHalfTheta < 0)\par
1582     \{\par
1583         q2.x = -q2.x; q2.y = -q2.y; q2.z = -q2.z; q2.w = -q2.w;\par
1584         cosHalfTheta = -cosHalfTheta;\par
1585     \}\par
1586 \par
1587     {\cf19 if} (fabs(cosHalfTheta) >= 1.0f) result = q1;\par
1588     {\cf19 else} {\cf19 if} (cosHalfTheta > 0.95f) result = QuaternionNlerp(q1, q2, amount);\par
1589     {\cf19 else}\par
1590     \{\par
1591         {\cf18 float} halfTheta = acosf(cosHalfTheta);\par
1592         {\cf18 float} sinHalfTheta = sqrtf(1.0f - cosHalfTheta*cosHalfTheta);\par
1593 \par
1594         {\cf19 if} (fabs(sinHalfTheta) < 0.001f)\par
1595         \{\par
1596             result.x = (q1.x*0.5f + q2.x*0.5f);\par
1597             result.y = (q1.y*0.5f + q2.y*0.5f);\par
1598             result.z = (q1.z*0.5f + q2.z*0.5f);\par
1599             result.w = (q1.w*0.5f + q2.w*0.5f);\par
1600         \}\par
1601         {\cf19 else}\par
1602         \{\par
1603             {\cf18 float} ratioA = sinf((1 - amount)*halfTheta)/sinHalfTheta;\par
1604             {\cf18 float} ratioB = sinf(amount*halfTheta)/sinHalfTheta;\par
1605 \par
1606             result.x = (q1.x*ratioA + q2.x*ratioB);\par
1607             result.y = (q1.y*ratioA + q2.y*ratioB);\par
1608             result.z = (q1.z*ratioA + q2.z*ratioB);\par
1609             result.w = (q1.w*ratioA + q2.w*ratioB);\par
1610         \}\par
1611     \}\par
1612 \par
1613     {\cf19 return} result;\par
1614 \}\par
}
}
