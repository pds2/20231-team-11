218 RMAPI Vector2 Vector2Add(Vector2 v1, Vector2 v2)\par
219 \{\par
220     Vector2 result = \{ v1.x + v2.x, v1.y + v2.y \};\par
221 \par
222     {\cf19 return} result;\par
223 \}\par
224 \par
