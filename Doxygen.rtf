1193 {\cf20 // Get zyx-rotation matrix (angles in radians)}\par
1194 RMAPI Matrix MatrixRotateZYX(Vector3 ang)\par
1195 \{\par
1196     Matrix result = \{ 0 \};\par
1197 \par
1198     {\cf18 float} cz = cosf(ang.z);\par
1199     {\cf18 float} sz = sinf(ang.z);\par
1200     {\cf18 float} cy = cosf(ang.y);\par
1201     {\cf18 float} sy = sinf(ang.y);\par
1202     {\cf18 float} cx = cosf(ang.x);\par
1203     {\cf18 float} sx = sinf(ang.x);\par
1204 \par
1205     result.m0 = cz*cy;\par
1206     result.m1 = cz*sy*sx - cx*sz;\par
1207     result.m2 = sz*sx + cz*cx*sy;\par
1208     result.m3 = 0;\par
1209 \par
1210     result.m4 = cy*sz;\par
1211     result.m5 = cz*cx + sz*sy*sx;\par
1212     result.m6 = cx*sz*sy - cz*sx;\par
1213     result.m7 = 0;\par
1214 \par
1215     result.m8 = -sy;\par
1216     result.m9 = cy*sx;\par
1217     result.m10 = cy*cx;\par
1218     result.m11 = 0;\par
1219 \par
1220     result.m12 = 0;\par
1221     result.m13 = 0;\par
1222     result.m14 = 0;\par
1223     result.m15 = 1;\par
1224 \par
1225     {\cf19 return} result;\par
1226 \}\par
